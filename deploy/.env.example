# Copy to .env (in the repository root, next to deploy/) and adjust as
# needed. All of these have safe defaults baked into the application —
# only set what you need to change. See internal/config/config.go for the
# authoritative list and defaults.

# Address the HTTP server binds to. Defaults to localhost-only; change to
# 0.0.0.0:8080 only when running inside a container network you trust, and
# always put a TLS-terminating reverse proxy in front for anything beyond
# local access.
BACKORBIT_HTTP_ADDR=127.0.0.1:8080

# Where SQLite and other persistent data live.
BACKORBIT_DATA_DIR=/var/lib/back-orbit

# Where local backup repositories are offered by default. This is a mount
# point your deployment provides, and it must be a different volume from
# BACKORBIT_DATA_DIR: backups stored beside the database are lost by the
# same accident that loses the database. Back-Orbit refuses a repository
# inside its own data directory for that reason.
BACKORBIT_BACKUP_DIR=/backups

# Docker daemon endpoint: unix:///var/run/docker.sock, or
# tcp://docker-socket-proxy:2375 when using the socket proxy setup.
BACKORBIT_DOCKER_HOST=unix:///var/run/docker.sock

# Session cookie name and lifetime.
BACKORBIT_SESSION_COOKIE=backorbit_session
BACKORBIT_SESSION_TTL=24h

# Set to true only when Back-Orbit is running behind a reverse proxy you
# trust to set X-Forwarded-Proto correctly — this affects whether cookies
# are marked Secure.
BACKORBIT_TRUST_PROXY_HEADERS=false

# Path to a file holding the secret store's master passphrase, so the store
# unlocks itself after a restart and scheduled backups keep running without
# someone typing it in. Use a Docker secret (see
# deploy/docker-compose.secret.yml); the file must not be readable by group or
# others, and Back-Orbit refuses it if it is.
#
# There is no environment variable for the passphrase itself, on purpose: the
# key to every other credential does not belong in a process environment.
# BACKORBIT_MASTER_KEY_FILE=/run/secrets/backorbit_master_key

# The GID that owns /var/run/docker.sock, used by docker-compose.yml's
# group_add. 0 (root) is correct for Docker Desktop (macOS/Windows) and is
# the default. On native Linux Docker, find the real value from inside a
# container (a host-side `stat` can be misleading on Docker Desktop):
#   docker run --rm -v /var/run/docker.sock:/var/run/docker.sock alpine stat -c '%g' /var/run/docker.sock
DOCKER_GID=0
