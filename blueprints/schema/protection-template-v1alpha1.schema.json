{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://back-orbit.io/schemas/protection-template-v1alpha1.json",
  "title": "Back-Orbit Protection Template",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "kind", "metadata", "match", "plan"],
  "properties": {
    "apiVersion": { "const": "back-orbit.io/v1alpha1" },
    "kind": { "const": "ProtectionTemplate" },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "version", "category", "upstream"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$", "maxLength": 80 },
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "upstream": { "type": "string", "format": "uri" },
        "tags": { "type": "array", "items": { "type": "string" }, "uniqueItems": true }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredImageGroups"],
      "properties": {
        "requiredImageGroups": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9._-]+(?:/[a-z0-9._-]+)*$" } }
        },
        "optionalImageGroups": {
          "type": "array",
          "items": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1, "pattern": "^[a-z0-9._-]+(?:/[a-z0-9._-]+)*$" } }
        },
        "requiredTechnologies": { "type": "array", "items": { "type": "string" } },
        "optionalTechnologies": { "type": "array", "items": { "type": "string" } }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["classification", "consistency", "requiredData", "restoreChecks"],
      "properties": {
        "classification": { "enum": ["rebuildable", "configuration-only", "stateful-filesystem", "stateful-database", "stateful-mixed", "unknown"] },
        "consistency": { "enum": ["crash-consistent", "filesystem-consistent", "application-consistent"] },
        "requiredData": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "databaseStrategy": { "type": "array", "items": { "type": "string" } },
        "includeHints": { "type": "array", "items": { "type": "string" } },
        "excludeHints": { "type": "array", "items": { "type": "string" } },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "restoreChecks": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
